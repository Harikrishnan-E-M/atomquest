{
  "name": "atomquest",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prebuild": "corepack pnpm --filter @atomquest/shared build",
    "dev": "corepack pnpm -r --parallel dev",
    "build": "corepack pnpm -r build",
    "build:web": "corepack pnpm --filter @atomquest/web build",
    "build:api": "corepack pnpm --filter @atomquest/api build",
    "lint": "corepack pnpm -r lint",
    "format": "corepack pnpm -r format",
    "check": "corepack pnpm -r check",
    "seed": "corepack pnpm --filter @atomquest/api seed"
  }
}